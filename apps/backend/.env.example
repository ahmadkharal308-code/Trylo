# Copy this file to `.env` and adjust as needed.
# NEVER commit a real `.env` with production secrets — it is gitignored.

# --- Database ---------------------------------------------------------------
# Points at the local PostgreSQL started by `docker compose up -d` (repo root).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://trylo:trylo_local_dev@localhost:5432/trylo?schema=public"

# --- App --------------------------------------------------------------------
# Port the backend HTTP server listens on.
PORT=3000

# Node environment: development | production | test
NODE_ENV=development
