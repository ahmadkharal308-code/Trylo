# Copy this file to `.env` and adjust as needed.
# NEVER commit a real `.env` with production secrets — it is gitignored.

# --- Database ---------------------------------------------------------------
# Points at the local PostgreSQL started by `docker compose up -d` (repo root).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://trylo:trylo_local_dev@localhost:5432/trylo?schema=public"

# --- App --------------------------------------------------------------------
# Port the backend HTTP server listens on.
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# --- Auth -------------------------------------------------------------------
# Long random string used to sign JWTs. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REPLACE this before going anywhere near production.
JWT_SECRET=REPLACE_ME_BEFORE_PRODUCTION
# How long access tokens live (e.g. "7d", "24h")
JWT_EXPIRES_IN=7d

# --- SMS / OTP --------------------------------------------------------------
# The OTP service is STUBBED in development: codes are logged to the console
# instead of being sent via SMS. To wire up a real provider, implement
# SmsProvider in src/modules/sellers/sms/sms.provider.ts and set these vars.
#
# Recommended providers for Pakistan:
#   - Twilio (global, works in PK, per-SMS cost ~$0.07)
#   - Infobip (strong PK coverage, competitive pricing)
#   - Jazz/Telenor direct API (local, cheapest for PK-only)
#
# SMS_PROVIDER=stub        # stub | twilio | infobip
# SMS_TWILIO_SID=
# SMS_TWILIO_TOKEN=
# SMS_TWILIO_FROM=
SMS_PROVIDER=stub
